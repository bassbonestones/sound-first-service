APP_NAME=Sound First Service
ENV=local
# SQLite for local development
DATABASE_URL="sqlite:///./sound_first.db"
ALEMBIC_DATABASE_URL="sqlite:///./sound_first.db"
# Supabase (uncomment when network is available)
#DATABASE_URL="postgresql+asyncpg://postgres:hVWbqV&Az3Z8Z2+@db.zckdczwukfzlakfyomqq.supabase.co:5432/postgres"
#ALEMBIC_DATABASE_URL="postgresql://postgres:hVWbqV&Az3Z8Z2+@db.zckdczwukfzlakfyomqq.supabase.co:5432/postgres"
#hVWbqV&Az3Z8Z2+   hVWbqV%26Az3Z8Z2%2B

# Audio: true = direct fluidsynth subprocess (works at work), false = midi2audio library
USE_DIRECT_FLUIDSYNTH=true

# =============================================================================
# OMR Settings (added by setup_omr.sh)
# =============================================================================
OMR_PROVIDER=mock
AUDIVERIS_PATH=/Applications/Audiveris.app/Contents/app/audiveris.jar
AUDIVERIS_JAVA_PATH=/Library/Java/JavaVirtualMachines/microsoft-25.jdk/Contents/Home/bin/java
REDIS_URL=redis://localhost:6379/0
